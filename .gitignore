# Database (contains real shop data — never commit)
app/database/pos.db
app/database/pos.db-*
app/database/backups/*.db

# Uploaded product images (user content, not source code)
app/public/assets/uploads/*
!app/public/assets/uploads/.gitkeep

# Portable PHP runtime (downloaded automatically by build_exe.py / launch.py)
php/
_php_download.zip
_php_tmp.zip

# Build output
dist/
_build/
*.spec

# Python
__pycache__/
*.pyc

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
